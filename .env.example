# StockPulse 로컬 인프라 환경변수 템플릿 (WBS 0-2)
# 사용법: 이 파일을 .env 로 복사 후 값 수정 →  cp .env.example .env
# 실제 .env 는 .gitignore 로 커밋 제외됨. 이 .env.example 만 추적된다.
# ⚠️ 비밀번호는 전부 더미(changeme). 실제 외부 API 키(KIS/네이버/DART), JWT_SECRET 는 WBS 0-3에서 추가.

# ── 포트 (호스트 충돌 시 변경) ──────────────────────────────
KAFKA_PORT=9092
REDIS_PORT=6379
POSTGRES_PORT=5432
TIMESCALE_PORT=5433       # postgres(5432)와 충돌 회피용
MONGO_PORT=27017

# ── PostgreSQL (트랜잭션용) ─────────────────────────────────
POSTGRES_USER=stockpulse
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stockpulse

# ── TimescaleDB (시계열 시세) ───────────────────────────────
TIMESCALE_USER=stockpulse
TIMESCALE_PASSWORD=changeme
TIMESCALE_DB=market

# ── MongoDB ─────────────────────────────────────────────────
MONGO_USER=stockpulse
MONGO_PASSWORD=changeme
MONGO_DB=stockpulse

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── Kafka KRaft 클러스터 ID ─────────────────────────────────
# 새 값 생성: docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
